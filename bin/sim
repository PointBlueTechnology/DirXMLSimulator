#!/bin/sh
# DirXML Policy Simulator CLI launcher.
#
# Requires JDK 21 (the 4.10.1 engine jars are Java 21 bytecode). Resolution order:
#   1. $SIM_JAVA_HOME if set
#   2. /usr/libexec/java_home -v 21 (macOS)
#   3. common JVM locations
HERE=$(cd "$(dirname "$0")/.." && pwd)

find_java21() {
    if [ -n "$SIM_JAVA_HOME" ] && [ -x "$SIM_JAVA_HOME/bin/java" ]; then
        echo "$SIM_JAVA_HOME"; return 0
    fi
    if [ -x /usr/libexec/java_home ]; then
        JH=$(/usr/libexec/java_home -v 21 2>/dev/null) && [ -n "$JH" ] && { echo "$JH"; return 0; }
    fi
    for c in \
        "$HOME/Library/Java/JavaVirtualMachines"/*21*/Contents/Home \
        /Library/Java/JavaVirtualMachines/*21*/Contents/Home \
        /usr/lib/jvm/*21*; do
        [ -x "$c/bin/java" ] && { echo "$c"; return 0; }
    done
    return 1
}

JH=$(find_java21) || {
    echo "ERROR: JDK 21 not found. Set SIM_JAVA_HOME to a JDK 21 home." >&2
    exit 4
}

# Resolve the application code: a dev build (target/classes), a packaged jar
# (release distribution), or build it if neither is present.
if [ -d "$HERE/target/classes" ]; then
    APP="$HERE/target/classes"
elif [ -f "$(ls "$HERE"/dirxml-simulator-*.jar 2>/dev/null | head -1)" ]; then
    APP=$(ls "$HERE"/dirxml-simulator-*.jar | head -1)
elif [ -f "$(ls "$HERE"/target/dirxml-simulator-*.jar 2>/dev/null | head -1)" ]; then
    APP=$(ls "$HERE"/target/dirxml-simulator-*.jar | head -1)
else
    echo "building (no target/classes or jar found)…" >&2
    (cd "$HERE" && JAVA_HOME="$JH" mvn -q compile) || { echo "ERROR: build failed" >&2; exit 5; }
    APP="$HERE/target/classes"
fi

exec "$JH/bin/java" -cp "$APP:$HERE/lib/*" com.pointblue.dirxml.sim.Cli "$@"
